# OpenAI API Key (from platform.openai.com)
OPENAI_API_KEY=

# 0G Storage Configuration
# Your EVM private key funded with 0G Testnet tokens (for paying storage fees on-chain)
ZG_PRIVATE_KEY=

# 0G Testnet EVM RPC URL
NEXT_PUBLIC_ZG_EVM_RPC=https://evmrpc-testnet.0g.ai

# 0G Testnet Indexer RPC URL (Turbo/Standard)
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# 0G Flow Contract Address (Testnet)
# Usually derived by the SDK, but can be explicitly set if needed
NEXT_PUBLIC_ZG_FLOW_ADDRESS=0x0400077700000000000000000000000000000000
